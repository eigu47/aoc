		fi
	done

	if (( ${#bits0[@]} > ${#bits1[@]} )); then
		for row in "${bits0[@]}"; do
			unset 'bits[row]'
		done
	else
		for row in "${bits1[@]}"; do
			unset 'bits[row]'
		done
	fi
done

rating0="${bits[*]}"

echo $((2#$rating1 * 2#$rating0))
